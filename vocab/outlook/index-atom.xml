    &lt;span class=&quot;hljs-attr&quot;&gt;&amp;quot;xsd&amp;quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;:&lt;/span&gt;     &lt;span class=&quot;hljs-string&quot;&gt;&amp;quot;http://www.w3.org/2001/XMLSchema#&amp;quot;&lt;/span&gt;&lt;span class=&quot;hljs-punctuation&quot;&gt;,&lt;/span&gt;

